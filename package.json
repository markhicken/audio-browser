{
  "name": "audio-browser",
  "version": "1.0.0",
  "description": "Simple local audio file browser with auto-play",
  "author": "Audio Browser <mark.hicken@gmail.com>",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron:start": "electron .",
    "build": "electron-builder",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux",
    "build-all": "npm run build-win && npm run build-mac && npm run build-linux"
  },
  "dependencies": {
    "express": "^5",
    "trash": "^10.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "electron": "^25.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.audiobrowser.app",
    "productName": "Audio Browser",
    "icon": "assets/icon.png",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "compression": "maximum",
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
